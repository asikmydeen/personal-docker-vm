# =============================================================================
# Claude Code Dev VM — Environment Configuration
# Copy this to .env and fill in your values:  cp env.example .env
# =============================================================================

# ---- SSH Access -------------------------------------------------------------
# Paste your public SSH key here (for SSH into the container)
SSH_PUBLIC_KEY=ssh-ed25519 AAAA... your-key-here

# ---- AWS Bedrock Bearer Token -----------------------------------------------
# This is used by Claude Code to authenticate with Bedrock
AWS_BEARER_TOKEN_BEDROCK=

# ---- AWS Bedrock Credentials (optional — if not using bearer token) ---------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ---- AWS Region -------------------------------------------------------------
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# ---- Claude Code Model (Bedrock) -------------------------------------------
# Available Bedrock model IDs:
#   us.anthropic.claude-sonnet-4-20250514-v1:0   (Sonnet 4 — fast, good balance)
#   us.anthropic.claude-opus-4-0-20250514-v1:0   (Opus 4 — most capable)
#   us.anthropic.claude-haiku-4-5-20251001-v1:0  (Haiku 4.5 — fastest, cheapest)
ANTHROPIC_MODEL=us.anthropic.claude-sonnet-4-20250514-v1:0

# ---- Git Configuration -----------------------------------------------------
GIT_USER_NAME=
GIT_USER_EMAIL=

# ---- Container Runtime Socket (for Fleet) ----------------------------------
# Docker:  /var/run/docker.sock  (default)
# Podman:  /run/podman/podman.sock
# Leave blank to auto-detect via start.sh
CONTAINER_SOCK=
